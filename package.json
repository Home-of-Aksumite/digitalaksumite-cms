{
  "name": "digitalaksumite-cms",
  "version": "1.0.0",
  "description": "Digital Aksumite CMS - Powered by Payload",
  "type": "module",
  "scripts": {
    "dev": "cross-env PORT=8000 PAYLOAD_CONFIG_PATH=src/payload.config.ts next dev --webpack",
    "prebuild": "npm run generate:importmap",
    "build": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts next build --webpack",
    "start": "cross-env PORT=8000 PAYLOAD_CONFIG_PATH=src/payload.config.ts next start",
    "typecheck": "tsc --noEmit",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap",
    "seed": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts tsx src/seed/index.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-s3": "3.83.0",
    "cli-color": "^2.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "next": "16.2.4",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
